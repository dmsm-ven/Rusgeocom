<Window x:Class="Rusgeocom.StartProductIdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Title="" Height="98" Width="131">
    <StackPanel Margin="6">
        <TextBlock Text="Стартовый ID" Margin="2"/>
        <TextBox x:Name="txtStartId" Text="-1"  Margin="2"/>
        <Button x:Name="btnOk" IsDefault="True" IsCancel="True" Content="Подтвердить" Margin="2"/>
    </StackPanel>
</Window>
